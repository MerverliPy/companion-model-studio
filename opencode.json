{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "coverage/**",
      ".git/**"
    ]
  },
  "instructions": ["AGENTS.md"]
}
